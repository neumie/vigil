{
	"name": "helm",
	"productName": "Helm",
	"private": true,
	"version": "0.1.0",
	"description": "Orchestrator cockpit for the helm daemon: native sidebar + real terminal",
	"main": "dist/main.cjs",
	"scripts": {
		"build": "npm --prefix .. run build && tsc --noEmit && node build.mjs",
		"start": "bun run build && electron .",
		"rebuild": "electron-rebuild -f -w node-pty",
		"postinstall": "electron-rebuild -f -w node-pty",
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build"
	},
	"dependencies": {
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-serialize": "^0.14.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/xterm": "^6.0.0",
		"node-pty": "^1.1.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@electron/rebuild": "^4.1.0",
		"@storybook/react-vite": "^10.5.0",
		"@types/node": "^24.0.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"electron": "^43.0.0",
		"esbuild": "^0.28.1",
		"storybook": "^10.5.0",
		"typescript": "^5.9.3",
		"vite": "^8.1.4"
	},
	"trustedDependencies": ["electron", "node-pty", "@electron/rebuild"]
}
