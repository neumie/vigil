{
	"compilerOptions": {
		"strict": true,
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"types": ["node"],
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"verbatimModuleSyntax": true,
		"forceConsistentCasingInFileNames": true,
		"noUncheckedIndexedAccess": true
	},
	"include": ["src"],
	// Storybook stays out of the app build (design-system.md §7): stories
	// typecheck via .storybook/tsconfig.json, not the `bun run build` tsc pass.
	"exclude": ["src/**/*.stories.tsx"]
}
