{
	"name": "helm",
	"private": true,
	"version": "0.1.0",
	"description": "Orchestrator cockpit for the vigil daemon: embedded dashboard + real terminal",
	"main": "dist/main.cjs",
	"scripts": {
		"build": "tsc --noEmit && node build.mjs",
		"start": "bun run build && electron .",
		"rebuild": "electron-rebuild -f -w node-pty",
		"postinstall": "electron-rebuild -f -w node-pty"
	},
	"dependencies": {
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/xterm": "^6.0.0",
		"node-pty": "^1.1.0"
	},
	"devDependencies": {
		"@electron/rebuild": "^4.1.0",
		"@types/node": "^24.0.0",
		"electron": "^43.0.0",
		"esbuild": "^0.28.1",
		"typescript": "^5.9.3"
	},
	"trustedDependencies": [
		"electron",
		"node-pty",
		"@electron/rebuild"
	]
}
